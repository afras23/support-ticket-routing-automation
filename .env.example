# Application environment: development | production | test
APP_ENV=development

# SQLite path (relative to working directory) or a full connection string.
# For Docker: sqlite:///./data/tickets.db
DATABASE_URL=sqlite:///./tickets.db

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Default confidence score assigned by the rule-based classifier (0.0–1.0).
CONFIDENCE_DEFAULT=0.82

# Minimum confidence required for a ticket to be auto-routed without review.
CONFIDENCE_THRESHOLD_AUTO_ROUTE=0.70

# Fallback channel when a ticket category has no explicit routing rule.
DEFAULT_CHANNEL=#support-general

# Port exposed by Docker Compose.
API_PORT=8000
